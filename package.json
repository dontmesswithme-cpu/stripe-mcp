{
  "name": "stripe-mcp",
  "version": "1.0.0",
  "description": "A production-grade Model Context Protocol server for the Stripe API",
  "keywords": [
    "mcp",
    "stripe",
    "model-context-protocol",
    "ai",
    "payments"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "./dist/index.js",
