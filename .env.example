# ──────────────────────────────────────────────
# Stripe MCP Server — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── REQUIRED ────────────────────────────────

# Your Stripe secret API key (starts with sk_test_ or sk_live_).
# Obtain from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=your_stripe_secret_key_here

# ─── OPTIONAL ────────────────────────────────

# Stripe API version to pin requests to (YYYY-MM-DD format).
# Defaults to the version bundled with the stripe npm package.
# See: https://stripe.com/docs/api/versioning
# STRIPE_API_VERSION=2025-04-30.basil

# Maximum number of objects returned in list operations (1–100).
# Defaults to 10 if not set.
# STRIPE_DEFAULT_LIMIT=10

# Log level for server diagnostics.
# One of: debug, info, warn, error. Defaults to info.
# LOG_LEVEL=info
