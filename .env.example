# ==============================================================================
# stripe-mcp v1.0.0 — Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Core credentials
# ------------------------------------------------------------------------------
# [REQUIRED] Your Stripe Secret Key.
# Use a restricted key with minimal permissions for production.
# Example: sk_test_51...
STRIPE_API_KEY=""

# ------------------------------------------------------------------------------
# Operating modes (dry-run, read-only)
# ------------------------------------------------------------------------------
# [OPTIONAL] If true, blocks all mutating operations (create, update, delete).
# Default: false
STRIPE_READ_ONLY=false

# [OPTIONAL] If true, runs the middleware pipeline (risk scoring, approvals, auditing)
# but simulates success without calling the Stripe API.
# Default: false
STRIPE_DRY_RUN=false

# [OPTIONAL] Directory to store SQLite databases (audit.db, approvals.db).
# Default: ./data
STRIPE_MCP_DATA_DIR="./data"

# ------------------------------------------------------------------------------
# Risk policy thresholds
# ------------------------------------------------------------------------------
# [OPTIONAL] Minimum score to block an operation entirely (70+).
# Default: 70
RISK_BLOCK_THRESHOLD=70

# [OPTIONAL] Minimum score to flag an operation and require approval (40-69).
# Default: 40
RISK_FLAG_THRESHOLD=40

# [OPTIONAL] Max velocity per customer in 24 hours. Exceeding this adds risk points.
# Default: 5
RISK_VELOCITY_24H_MAX=5

# [OPTIONAL] Max velocity per customer in 30 days. Exceeding this adds risk points.
# Default: 20
RISK_VELOCITY_30D_MAX=20

# [OPTIONAL] Amount considered "high" (in smallest currency unit). Adds risk points.
# Default: 50000 ($500.00)
RISK_AMOUNT_HIGH=50000

# [OPTIONAL] Amount considered "critical" (in smallest currency unit). Adds more risk points.
# Default: 200000 ($2,000.00)
RISK_AMOUNT_CRITICAL=200000

# ------------------------------------------------------------------------------
# Approval system
# ------------------------------------------------------------------------------
# [OPTIONAL] API Key required to authenticate approval/rejection requests.
# Default: dev_key_change_in_production
APPROVAL_API_KEY="dev_key_change_in_production"

# [OPTIONAL] Port for the HTTP approval server. Set to 0 to disable.
# Default: 3001
APPROVAL_PORT=3001

# [OPTIONAL] How long approval tokens remain valid (in minutes).
# Default: 60
APPROVAL_EXPIRY_MINUTES=60

# [OPTIONAL] Refunds above this amount (in smallest currency unit) require human approval.
# Default: 100000 ($1,000.00)
APPROVAL_REFUND_THRESHOLD=100000

# [OPTIONAL] Subscription cancellations above this amount (in smallest currency unit) require human approval.
# Default: 500000 ($5,000.00)
APPROVAL_CANCEL_THRESHOLD=500000

# ------------------------------------------------------------------------------
# Customer Archive Policy
# ------------------------------------------------------------------------------
# [OPTIONAL] How many days after archiving before a customer is permanently purged.
# Default: 14
ARCHIVE_DELETE_AFTER_DAYS=14
